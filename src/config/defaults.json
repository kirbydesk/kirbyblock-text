{
  "content": {
    "tagline": { "align": "left" },
    "heading": { "align": "left", "level": "h2", "size": "lg" },
    "editor":  { "align": "left", "size": "normal", "mode": "textarea" },
    "buttons": { "align": "left" }
  },
  "layout": {
    "padding-top": true,
    "padding-right": true,
    "padding-bottom": true,
    "padding-left": true,
    "radius-top-left": false,
    "radius-top-right": false,
    "radius-bottom-left": false,
    "radius-bottom-right": false
  },
  "style": {
    "theme": "default"
  },
  "grid": {
    "grid-size-sm": 12,
    "grid-size-md": 12,
    "grid-size-lg": 12,
    "grid-size-xl": 12,
    "grid-offset-sm": 0,
    "grid-offset-md": 0,
    "grid-offset-lg": 0,
    "grid-offset-xl": 0
  },
  "settings": {
		"block-size": "content",
    "margin-top": false,
    "margin-bottom": false
  }
}
